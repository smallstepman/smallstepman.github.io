+#[test]
+pub fn move_pane_to_tab_without_pane_id_uses_focused_pane_stable_tab_id_and_target_focus() {
+    // Start from the same mock-screen/session bootstrap as send_cli_go_to_tab_by_id_action.
+    // Shape tabs so the target tab's stable ID differs from its position:
+    //   create tabs 0, 1, 2 then close tab 1 → tab 2 moves to position=1 (stable_id=2 != pos=1).
+    // Record the invoking client's focused pane ID and the target tab's stable ID.
+    // Send CliAction::MovePaneToTab { tab_id: 2, pane_id: None }.
+    // Assert all 5 properties from the spec.
+    let size = Size { cols: 121, rows: 20 };
+    let client_id = 1u16;
+
+    // Source tab with 2 tiled panes so the source tab survives after one pane moves out.
+    let mut initial_layout = TiledPaneLayout::default();
+    initial_layout.children_split_direction = SplitDirection::Vertical;
+    initial_layout.children = vec![TiledPaneLayout::default(),TiledPaneLayout::default()];
+
+    let mut mock_screen = MockScreen::new(size);
+    let session_metadata = mock_screen.clone_session_metadata();
+
+    // Tab 0 (source, 2 panes); client starts focused here.
+    let screen_thread = mock_screen.run(Some(initial_layout), vec![]);
+    // Tab 1 (placeholder); client moves here.
+    mock_screen.new_tab(TiledPaneLayout::default());
+    // Tab 2 (target, 1 pane); client moves here.
+    mock_screen.new_tab(TiledPaneLayout::default());
+
+    std::thread::sleep(std::time::Duration::from_millis(100));
+
+    // Navigate client back to the source tab (stable ID=0).
+    let _ = mock_screen
+        .to_screen
+        .send(ScreenInstruction::GoToTabWithId(0, Some(client_id), None));
+    std::thread::sleep(std::time::Duration::from_millis(100));
+
+    // Close the placeholder tab (ID=1); tab 2 shifts to position=1 while keeping stable_id=2.
+    let _ = mock_screen
+        .to_screen
+        .send(ScreenInstruction::CloseTabWithId(1, None));
+    std::thread::sleep(std::time::Duration::from_millis(100));
+
+    // Record the focused pane ID for the invoking client.
+    let (pane_tx, pane_rx) = crossbeam::channel::bounded::<GetFocusedPaneInfoResponse>(1);
+    let _ = mock_screen
+        .to_screen
+        .send(ScreenInstruction::GetFocusedPaneInfo {
+            client_id,
+            response_channel: pane_tx,
+        });
+    let focused_pane_id = match pane_rx
+        .recv_timeout(std::time::Duration::from_secs(5))
+        .expect("timed out waiting for GetFocusedPaneInfo")
+    {
+        GetFocusedPaneInfoResponse::Ok { pane_id, .. } => pane_id,
+        GetFocusedPaneInfoResponse::Err(e) => {
+            panic!("GetFocusedPaneInfo error before move: {}", e)
+        },
+    };
+
+    // Set up server instruction logging (after setup so setup renders don't pollute counts).
+    let received_server_instructions = Arc::new(Mutex::new(vec![]));
+    let server_receiver = mock_screen.server_receiver.take().unwrap();
+    let server_thread = log_actions_in_thread!(
+        received_server_instructions,
+        ServerInstruction::KillSession,
+        server_receiver
+    );
+
+    // Send the CLI action using the target's stable tab ID=2 (which is at position=1, not position=2).
+    // A broken implementation that treats tab_id as a position would attempt position=2 (nonexistent).
+    let cli_action = CliAction::MovePaneToTab {
+        tab_id: 2,
+        pane_id: None,
+    };
+    send_cli_action_to_server(&session_metadata, cli_action, client_id);
+    std::thread::sleep(std::time::Duration::from_millis(100));
+
+    // ── Assertion 4: client is now focused on the target tab (stable ID=2) ──────────────────────
+    let (cur_tab_tx, cur_tab_rx) = crossbeam::channel::bounded::<Option<TabInfo>>(1);
+    let _ = mock_screen
+        .to_screen
+        .send(ScreenInstruction::GetCurrentTabInfo {
+            client_id,
+            response_channel: cur_tab_tx,
+        });
+    let current_tab = cur_tab_rx
+        .recv_timeout(std::time::Duration::from_secs(5))
+        .expect("timed out waiting for GetCurrentTabInfo after move")
+        .expect("client should be focused on a tab after move");
+    assert_eq!(
+        current_tab.tab_id, 2,
+        "client should be focused on tab with stable ID=2 after move"
+    );
+
+    // ── Assertion 3: did not accidentally target the tab merely occupying that position ──────────
+    // stable_id=2 is at position=1 (not position=2 which no longer exists).
+    assert_eq!(
+        current_tab.position, 1,
+        "target tab should be at position=1 (stable ID=2 must not be confused with position=2)"
+    );
+
+    // ── Assertions 1 & 2: verify pane membership using ListPanes ─────────────────────────────────
+    let (list_tx, list_rx) = crossbeam::channel::bounded::<ListPanesResponse>(1);
+    let _ = mock_screen
+        .to_screen
+        .send(ScreenInstruction::ListPanes {
+            show_all: true,
+            response_channel: list_tx,
+        });
+    let panes = list_rx
+        .recv_timeout(std::time::Duration::from_secs(5))
+        .expect("timed out waiting for ListPanes after move");
+
+    let (pane_id_u32, pane_is_plugin) = match focused_pane_id {
+        DataPaneId::Terminal(id) => (id, false),
+        DataPaneId::Plugin(id) => (id, true),
+    };
+
+    // Assertion 1: the source tab (ID=0) no longer contains the recorded pane.
+    let pane_in_source = panes.iter().any(|entry| {
+        entry.pane_info.id == pane_id_u32
+            && entry.pane_info.is_plugin == pane_is_plugin
+            && entry.tab_id == 0
+    });
+    assert!(
+        !pane_in_source,
+        "source tab (ID=0) should no longer contain the moved pane after move"
+    );
+
+    // Assertion 2: the tab with stable ID=2 now contains the moved pane.
+    let pane_in_target = panes.iter().any(|entry| {
+        entry.pane_info.id == pane_id_u32
+            && entry.pane_info.is_plugin == pane_is_plugin
+            && entry.tab_id == 2
+    });
+    assert!(
+        pane_in_target,
+        "target tab (stable ID=2) should contain the moved pane after move"
+    );
+
+    mock_screen.teardown(vec![server_thread,screen_thread]);
+
+    // ── Assertion 5: the action still triggers screen renders ────────────────────────────────────
+    let render_count = received_server_instructions
+        .lock()
+        .unwrap()
+        .iter()
+        .filter(|instr| matches!(instr, ServerInstruction::Render(_)))
+        .count();
+    assert!(
+        render_count > 0,
+        "MovePaneToTab CLI action should trigger screen renders; got {}",
+        render_count
+    );
+}
