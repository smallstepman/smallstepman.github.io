+        command.write_long_help(&mut help).unwrap();
+        let help = String::from_utf8(help).unwrap();
+        assert!(help.contains("inject"));
+    }
+
+    #[test]
+    fn test_help_mentions_inject_run_flag() {
+        let mut command = Opt::command();
+        let inject = command.find_subcommand_mut("inject").unwrap();
+        let mut help = Vec::new();
+        inject.write_long_help(&mut help).unwrap();
+        let help = String::from_utf8(help).unwrap();
+        assert!(help.contains("--in-file"));
+        assert!(help.contains("--out-file"));
+        assert!(help.contains("--run"));
+        assert!(help.contains("Use as: [OPTIONS] --run -- <COMMAND> [ARGS...]"));
+        assert!(help.contains("Usage: rbw inject [OPTIONS]"));
+        assert!(help.contains("rbw inject [OPTIONS] --run -- <COMMAND> [ARGS...]"));
+        assert!(!help.contains("--input"));
+        assert!(!help.contains("--output"));
+    }
+
+    #[test]
+    fn test_inject_run_requires_child_command() {
+        let err = Opt::try_parse_from(["rbw", "inject", "--run"]).unwrap_err();
+        assert_eq!(err.kind(), clap::error::ErrorKind::MissingRequiredArgument);
+        let err = err.to_string();
+        assert!(err.contains("Usage: rbw inject [OPTIONS]"));
+        assert!(err.contains("rbw inject [OPTIONS] --run -- <COMMAND> [ARGS...]"));
+    }
+
+    #[test]
+    fn test_inject_accepts_in_file_and_out_file_long_flags() {
+        assert!(Opt::try_parse_from(["rbw", "inject", "--in-file", "x"]).is_ok());
+        assert!(Opt::try_parse_from(["rbw", "inject", "--out-file", "x"]).is_ok());
+        assert!(Opt::try_parse_from(["rbw", "inject", "--in-file", "x", "--run", "--", "env"])
+            .is_ok());
+    }
+
+    #[test]
+    fn test_inject_run_accepts_child_command_after_double_dash() {
+        let opt =
+            Opt::try_parse_from(["rbw", "inject", "--run", "--", "env", "-0"]).unwrap();
+
+        match opt {
+            Opt::Inject {
+                input,
+                output,
+                run,
+                command,
+            } => {
+                assert_eq!(input, None);
+                assert_eq!(output, None);
+                assert!(run);
+                assert_eq!(
+                    command,
+                    vec![
+                        std::ffi::OsString::from("env"),
+                        std::ffi::OsString::from("-0"),
+                    ]
+                );
+            }
+            _ => panic!("expected inject command"),
+        }
+    }
+
+    #[test]
+    fn test_inject_run_rejects_child_command_without_double_dash() {
+        let err = Opt::try_parse_from(["rbw", "inject", "--run", "env"]).unwrap_err();
+        assert_eq!(err.kind(), clap::error::ErrorKind::UnknownArgument);
+    }
+
+    #[test]
+    fn test_inject_rejects_stray_double_dash_without_run() {
+        let err = Opt::try_parse_from(["rbw", "inject", "--", "env"]).unwrap_err();
+        assert_eq!(err.kind(), clap::error::ErrorKind::MissingRequiredArgument);
+        let err = err.to_string();
+        assert!(err.contains("the following required arguments were not provided:"));
+        assert!(err.contains("--run"));
+    }
+
+    #[test]
+    fn test_inject_accepts_in_file_and_out_file_short_flags() {
+        let opt = Opt::try_parse_from([
+            "rbw", "inject", "-i", "input.tmpl", "-o", "output.env",
+        ])
+        .unwrap();
+
+        match opt {
+            Opt::Inject { input, output, .. } => {
+                assert_eq!(input.unwrap(), std::path::PathBuf::from("input.tmpl"));
+                assert_eq!(output.unwrap(), std::path::PathBuf::from("output.env"));
+            }
+            _ => panic!("expected inject command"),
+        }
+    }
+
+    #[test]
+    fn test_prepare_inject_action_rejects_run_with_out_file() {
+        let err = prepare_inject_action(
+            None,
+            Some(std::path::Path::new("output.env")),
+            true,
+            &[std::ffi::OsString::from("env")],
+        )
+        .unwrap_err();
+        assert_eq!(
+            err.to_string(),
+            "inject --run does not support --out-file/-o"
+        );
+    }
+
+    #[test]
+    fn test_prepare_inject_action_returns_run_command_for_run_mode() {
+        let command = [
+            std::ffi::OsString::from("env"),
+            std::ffi::OsString::from("-0"),
+        ];
+        let action =
+            prepare_inject_action(None, None, true, &command).unwrap();
+
+        match action {
+            InjectAction::RunCommand { input, command: actual } => {
+                assert_eq!(input, None);
+                assert_eq!(actual, command);
+            }
+            InjectAction::RenderTemplate { .. } => {
+                panic!("expected run command action")
+            }
+        }
+    }
