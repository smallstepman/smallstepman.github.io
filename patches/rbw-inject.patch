+fn render_inject_template<F>(
+    template: &str,
+    mut resolver: F,
+) -> anyhow::Result<String>
+where
+    F: FnMut(&InjectReference) -> anyhow::Result<String>,
+{
+    let mut rendered = String::with_capacity(template.len());
+    let mut start = 0;
+    while let Some((idx, marker)) = next_inject_marker(template, start) {
+        rendered.push_str(&template[start..idx]);
+        match marker {
+            InjectMarker::Braced => {
+                let rest = &template[idx + 2..];
+                let Some(end) = rest.find("}}") else {
+                    anyhow::bail!("unterminated inject template expression");
+                };
+                let end = idx + 2 + end;
+                let expr = template[idx + 2..end].trim();
+                if let Some(reference) = expr.strip_prefix("bw://") {
+                    let reference =
+                        parse_inject_reference(&format!("bw://{reference}"))?;
+                    rendered.push_str(&resolver(&reference)?);
+                } else {
+                    rendered.push_str(&template[idx..end + 2]);
+                }
+                start = end + 2;
+            }
+            InjectMarker::Raw => {
+                let end = raw_reference_end(template, idx);
+                let prefix = &template[..idx];
+                let (reference, split) = parse_raw_inject_reference(
+                    &template[idx..end],
+                    prefix.ends_with(':') || prefix.ends_with("://"),
+                    prefix.ends_with('='),
+                )?;
+                rendered.push_str(&resolver(&reference)?);
+                start = idx + split;
+            }
+        }
+    }
+    rendered.push_str(&template[start..]);
+    Ok(rendered)
+}
 
