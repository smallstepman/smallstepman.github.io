+pub fn inject_run(
+    input: Option<&std::path::Path>,
+    command: &[OsString],
+) -> anyhow::Result<std::process::ExitStatus> {
+    unlock()?;
+
+    let db = load_db()?;
+    let template = read_inject_template(input)?;
+    let env_bindings = parse_inject_run_env(&template, |reference| {
+        resolve_inject_reference(&db, reference)
+    })?;
+    run_inject_command(command, &env_bindings)
+}
