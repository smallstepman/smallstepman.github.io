+
+fn parse_inject_run_env<F>(
+    template: &str,
+    mut resolver: F,
+) -> anyhow::Result<Vec<(String, String)>>
+where
+    F: FnMut(&InjectReference) -> anyhow::Result<String>,
+{
+    let mut pairs = Vec::new();
+    for (idx, raw_line) in template.lines().enumerate() {
+        let line_number = idx + 1;
+        let line = raw_line.trim();
+        if line.is_empty() || line.starts_with('#') {
+            continue;
+        }
+        if line.starts_with("export ") {
+            anyhow::bail!(
+                "line {line_number}: unsupported shell syntax 'export'; use KEY=value"
+            );
+        }
+
+        let Some((raw_key, raw_value)) = line.split_once('=') else {
+            anyhow::bail!(
+                "line {line_number}: missing '=' in dotenv assignment"
+            );
+        };
+        let key = raw_key.trim();
+        if key.is_empty() {
+            anyhow::bail!(
+                "line {line_number}: dotenv assignment is missing a key"
+            );
+        }
+        if key.contains(char::is_whitespace) {
+            anyhow::bail!(
+                "line {line_number}: unsupported whitespace in dotenv key '{key}'"
+            );
+        }
+
+        let value_template =
+            parse_inject_dotenv_value(raw_value, line_number)?;
+        let value = render_inject_template(&value_template, |reference| {
+            resolver(reference)
+        })?;
+        pairs.push((key.to_string(), value));
+    }
+    Ok(pairs)
+}
+
+fn parse_inject_dotenv_value(
+    raw_value: &str,
+    line_number: usize,
+) -> anyhow::Result<String> {
+    let value = raw_value.trim_start();
+    match value.chars().next() {
+        Some(quote @ ('\'' | '"')) => {
+            parse_inject_dotenv_quoted_value(value, quote, line_number)
+        }
+        _ => Ok(parse_inject_dotenv_unquoted_value(raw_value)),
+    }
+}
+
+fn parse_inject_dotenv_unquoted_value(raw_value: &str) -> String {
+    let Some(start) = raw_value.find(|ch: char| !ch.is_whitespace()) else {
+        return String::new();
+    };
+
+    for (offset, ch) in raw_value[start..].char_indices() {
+        let idx = start + offset;
+        if ch != '#' {
+            continue;
+        }
+
+        let preceded_by_whitespace = idx > 0
+            && raw_value[..idx]
+                .chars()
+                .next_back()
+                .is_some_and(char::is_whitespace);
+        if preceded_by_whitespace {
+            return raw_value[start..idx].trim_end().to_string();
+        }
+    }
+
+    raw_value[start..].trim_end().to_string()
+}
+
+fn parse_inject_dotenv_quoted_value(
+    value: &str,
+    quote: char,
+    line_number: usize,
+) -> anyhow::Result<String> {
+    let mut chars = value.chars();
+    let Some(opening) = chars.next() else {
+        return Ok(String::new());
+    };
+    debug_assert_eq!(opening, quote);
+
+    let mut parsed = String::new();
+    let mut chars = chars.as_str().char_indices().peekable();
+    while let Some((idx, ch)) = chars.next() {
+        if ch == quote {
+            let trailing =
+                &value[idx + opening.len_utf8() + quote.len_utf8()..];
+            if trailing.trim().is_empty() {
+                return Ok(parsed);
+            }
+            if trailing.starts_with(char::is_whitespace)
+                && trailing.trim_start().starts_with('#')
+            {
+                return Ok(parsed);
+            }
+            anyhow::bail!(
+                "line {line_number}: unsupported trailing characters after quoted dotenv value"
+            );
+        }
+
+        if quote == '"' && ch == '\\' {
+            match chars.peek().map(|(_, ch)| *ch) {
+                Some('\\' | '"') => {
+                    parsed.push(chars.next().expect("peeked escape char").1);
+                }
+                Some(_) => parsed.push('\\'),
+                None => {
+                    anyhow::bail!(
+                        "line {line_number}: unterminated escape sequence in quoted dotenv value"
+                    );
+                }
+            }
+            continue;
+        }
+
+        parsed.push(ch);
+    }
+
+    anyhow::bail!("line {line_number}: unterminated quoted dotenv value")
+}
+
+fn build_inject_run_command(
+    command: &[OsString],
+    env_bindings: &[(String, String)],
+) -> anyhow::Result<std::process::Command> {
+    let Some(program) = command.first() else {
+        anyhow::bail!("missing child command");
+    };
+
+    let mut child = std::process::Command::new(program);
+    child.args(&command[1..]);
+    child.stdin(std::process::Stdio::inherit());
+    child.stdout(std::process::Stdio::inherit());
+    child.stderr(std::process::Stdio::inherit());
+    for (key, value) in env_bindings {
+        child.env(key, value);
+    }
+    Ok(child)
+}
+
+fn run_inject_command(
+    command: &[OsString],
+    env_bindings: &[(String, String)],
+) -> anyhow::Result<std::process::ExitStatus> {
+    let mut child = build_inject_run_command(command, env_bindings)?;
+    child.status().with_context(|| {
+        let program = command
+            .first()
+            .map(|program| program.to_string_lossy().into_owned())
+            .unwrap_or_else(|| "<missing command>".to_string());
+        format!("failed to run child command '{program}'")
+    })
+}
+
+fn next_inject_marker(
+    template: &str,
+    start: usize,
+) -> Option<(usize, InjectMarker)> {
+    let rest = &template[start..];
+    let braced = rest
+        .find("{{")
+        .map(|offset| (start + offset, InjectMarker::Braced));
+    let raw = rest
+        .match_indices("bw://")
+        .map(|(offset, _)| start + offset)
+        .find(|&idx| raw_reference_can_start(template, idx))
+        .map(|idx| (idx, InjectMarker::Raw));
+
+    match (braced, raw) {
+        (Some(braced), Some(raw)) => {
+            Some(if braced.0 <= raw.0 { braced } else { raw })
+        }
+        (Some(braced), None) => Some(braced),
+        (None, Some(raw)) => Some(raw),
+        (None, None) => None,
+    }
+}
+
+fn raw_reference_can_start(template: &str, idx: usize) -> bool {
+    template[..idx].chars().next_back().is_none_or(|ch| {
+        !ch.is_ascii_alphanumeric() && ch != '_' && ch != '-'
+    })
+}
+
+fn raw_reference_end(template: &str, start: usize) -> usize {
+    let mut end = start + "bw://".len();
+    for (offset, ch) in template[end..].char_indices() {
+        if is_raw_reference_delimiter(ch) {
+            break;
+        }
+        end = start + "bw://".len() + offset + ch.len_utf8();
+    }
+    end
+}
+
+fn is_raw_reference_delimiter(ch: char) -> bool {
+    ch.is_whitespace()
+        || matches!(
+            ch,
+            '"' | '\''
+                | '`'
+                | '<'
+                | '>'
+                | '('
+                | ')'
+                | '['
+                | ']'
+                | '{'
+                | '}'
+                | ','
+                | ';'
+        )
+}
+
+fn parse_raw_inject_reference(
+    candidate: &str,
+    allow_at_suffix: bool,
+    allow_amp_suffix: bool,
+) -> anyhow::Result<(InjectReference, usize)> {
+    if allow_at_suffix {
+        let mut last_valid = None;
+        for (idx, ch) in candidate.char_indices() {
+            if ch != '@' {
+                continue;
+            }
+            if let Ok(reference) = parse_inject_reference(&candidate[..idx]) {
+                last_valid = Some((reference, idx));
+            }
+        }
+        if let Some(split) = last_valid {
+            return Ok(split);
+        }
+    }
+
+    let err = match parse_inject_reference(candidate) {
+        Ok(reference) => return Ok((reference, candidate.len())),
+        Err(err) => err,
+    };
+
+    let mut last_valid = None;
+    for (idx, ch) in candidate.char_indices() {
+        if !is_raw_reference_suffix_delimiter(ch) {
+            continue;
+        }
+        let prefix = &candidate[..idx];
+        if matches!(ch, '.' | '!') && idx + ch.len_utf8() != candidate.len() {
+            continue;
+        }
+        if ch == '@' && !allow_at_suffix {
+            continue;
+        }
+        if ch == '&' && !allow_amp_suffix {
+            continue;
+        }
+        if let Ok(reference) = parse_inject_reference(prefix) {
+            last_valid = Some((reference, idx));
+        }
+    }
+
+    last_valid.ok_or(err)
+}
+
+fn is_raw_reference_suffix_delimiter(ch: char) -> bool {
+    matches!(ch, '@' | '&' | '.' | '!')
+}
+
+fn is_valid_inject_name(name: &str) -> bool {
+    !name.is_empty()
+        && name
+            .chars()
+            .all(|ch| ch.is_ascii_alphanumeric() || ch == '-' || ch == '_')
+}
+
+fn parse_inject_reference(
+    reference: &str,
+) -> anyhow::Result<InjectReference> {
+    let parsed = url::Url::parse(reference)
+        .with_context(|| format!("invalid inject reference '{reference}'"))?;
+    if parsed.scheme() != "bw" {
+        anyhow::bail!(
+            "invalid inject reference scheme '{}'",
+            parsed.scheme()
+        );
+    }
+    if parsed.fragment().is_some() {
+        anyhow::bail!("inject references do not support fragments");
+    }
+    if !parsed.username().is_empty() {
+        anyhow::bail!("inject references do not support usernames");
+    }
+    if parsed.password().is_some() {
+        anyhow::bail!("inject references do not support passwords");
+    }
+    if parsed.port().is_some() {
+        anyhow::bail!("inject references do not support ports");
+    }
+    if !parsed.path().is_empty() {
+        anyhow::bail!("inject references do not support paths");
+    }
+
+    let raw_target = parsed
+        .host_str()
+        .context("inject reference is missing an item id or name")?;
+    let target = if let Ok(uuid) = uuid::Uuid::parse_str(raw_target) {
+        InjectReferenceTarget::Uuid(uuid.to_string())
+    } else if is_valid_inject_name(raw_target) {
+        InjectReferenceTarget::Name(raw_target.to_string())
+    } else {
+        anyhow::bail!("invalid item uuid or supported name '{raw_target}'");
+    };
+
+    let mut field = None;
+    for (key, value) in parsed.query_pairs() {
+        match key.as_ref() {
+            "field" => {
+                if field.replace(value.into_owned()).is_some() {
+                    anyhow::bail!(
+                        "inject reference has multiple field parameters"
+                    );
+                }
+            }
+            _ => {
+                anyhow::bail!("unsupported inject query parameter '{}'", key)
+            }
+        }
+    }
+
+    let field = field
+        .map(|value| {
+            let trimmed = value.trim();
+            if trimmed.is_empty() {
+                anyhow::bail!("inject field query parameter cannot be empty");
+            }
+            Ok(trimmed.to_string())
+        })
+        .transpose()?;
+
+    Ok(InjectReference {
+        id: target.as_str().to_string(),
+        target,
+        field,
+    })
+}
+
+fn resolve_inject_reference(
+    db: &rbw::db::Db,
+    reference: &InjectReference,
+) -> anyhow::Result<String> {
+    let entries: Vec<(rbw::db::Entry, DecryptedSearchCipher)> = db
+        .entries
+        .iter()
+        .map(|entry| {
+            decrypt_search_cipher(entry)
+                .map(|decrypted| (entry.clone(), decrypted))
+        })
+        .collect::<anyhow::Result<_>>()?;
+    let (entry, _) = find_inject_entry_raw(&entries, &reference.target)?;
+    let decrypted = decrypt_cipher(&entry).with_context(|| {
+        format!("failed to decrypt entry '{}'", reference.id)
+    })?;
+    resolve_inject_value(&decrypted, reference.field.as_deref()).with_context(
+        || format!("failed to resolve inject reference '{}'", reference.id),
+    )
+}
+
+fn find_inject_entry_raw(
+    entries: &[(rbw::db::Entry, DecryptedSearchCipher)],
+    target: &InjectReferenceTarget,
+) -> anyhow::Result<(rbw::db::Entry, DecryptedSearchCipher)> {
+    let matches: Vec<(rbw::db::Entry, DecryptedSearchCipher)> = entries
+        .iter()
+        .filter(|(entry, decrypted)| match target {
+            InjectReferenceTarget::Uuid(id) => {
+                entry.id.eq_ignore_ascii_case(id)
+            }
+            InjectReferenceTarget::Name(name) => {
+                decrypted.name.eq_ignore_ascii_case(name)
+            }
+        })
+        .cloned()
+        .collect();
+
+    if matches.is_empty() {
+        match target {
+            InjectReferenceTarget::Uuid(id) => {
+                anyhow::bail!("no entry found for item id '{}'", id)
+            }
+            InjectReferenceTarget::Name(name) => {
+                anyhow::bail!("no entry found for item name '{}'", name)
+            }
+        }
+    } else if matches.len() == 1 {
+        Ok(matches[0].clone())
+    } else {
+        let entries: Vec<String> = matches
+            .iter()
+            .map(|(_, decrypted)| decrypted.display_name())
+            .collect();
+        match target {
+            InjectReferenceTarget::Name(name) => anyhow::bail!(
+                "multiple entries found for item name '{}': {}; use bw://<uuid> instead",
+                name,
+                entries.join(", ")
+            ),
+            InjectReferenceTarget::Uuid(id) => anyhow::bail!(
+                "multiple entries found for item id '{}': {}",
+                id,
+                entries.join(", ")
+            ),
+        }
+    }
+}
+
+fn resolve_inject_value(
+    cipher: &DecryptedCipher,
+    field: Option<&str>,
+) -> anyhow::Result<String> {
+    let normalized = field
+        .map(str::trim)
+        .filter(|field| !field.is_empty())
+        .map(str::to_lowercase);
+    match normalized.as_deref() {
+        None | Some("password") => match &cipher.data {
+            DecryptedData::Login {
+                password: Some(password),
+                ..
+            } => Ok(password.clone()),
+            DecryptedData::Login { .. } => {
+                anyhow::bail!("entry '{}' has no password", cipher.name)
+            }
+            _ => {
+                anyhow::bail!("entry '{}' is not a login entry", cipher.name)
+            }
+        },
+        Some("username") | Some("user") => match &cipher.data {
+            DecryptedData::Login {
+                username: Some(username),
+                ..
+            } => Ok(username.clone()),
+            DecryptedData::Login { .. } => {
+                anyhow::bail!("entry '{}' has no username", cipher.name)
+            }
+            _ => {
+                anyhow::bail!("entry '{}' is not a login entry", cipher.name)
+            }
+        },
+        Some(field) => cipher
+            .fields
+            .iter()
+            .find(|custom| {
+                custom
+                    .name
+                    .as_deref()
+                    .is_some_and(|name| name.eq_ignore_ascii_case(field))
+            })
+            .and_then(|custom| custom.value.clone())
+            .with_context(|| {
+                format!(
+                    "entry '{}' has no field named '{}'",
+                    cipher.name, field
+                )
+            }),
+    }
+}
+
+fn write_rendered_template_file(
+    path: &std::path::Path,
+    rendered: &str,
+) -> anyhow::Result<()> {
+    #[cfg(unix)]
+    {
+        match std::fs::symlink_metadata(path) {
+            Ok(metadata) => {
+                if metadata.file_type().is_symlink() {
+                    anyhow::bail!(
+                        "rendered template target '{}' must not be a symlink",
+                        path.display()
+                    );
+                }
+                if !metadata.file_type().is_file() {
+                    anyhow::bail!(
+                        "rendered template target '{}' is not a regular file",
+                        path.display()
+                    );
+                }
+            }
+            Err(err) if err.kind() == std::io::ErrorKind::NotFound => {}
+            Err(err) => {
+                return Err(err).with_context(|| {
+                    format!(
+                        "failed to inspect rendered template {}",
+                        path.display()
+                    )
+                });
+            }
+        }
+
+        let parent = match path.parent() {
+            Some(parent) if !parent.as_os_str().is_empty() => parent,
+            _ => std::path::Path::new("."),
+        };
+        let mut file = tempfile::Builder::new()
+            .prefix(".rbw-rendered-template.")
+            .tempfile_in(parent)
+            .with_context(|| {
+                format!(
+                    "failed to open temporary rendered template near {}",
+                    path.display()
+                )
+            })?;
+        file.as_file_mut()
+            .set_permissions(std::fs::Permissions::from_mode(0o600))
+            .with_context(|| {
+                format!(
+                    "failed to set secure permissions on {}",
+                    path.display()
+                )
+            })?;
+        file.write_all(rendered.as_bytes()).with_context(|| {
+            format!("failed to write rendered template {}", path.display())
+        })?;
+        file.as_file_mut().sync_all().with_context(|| {
+            format!("failed to sync rendered template {}", path.display())
+        })?;
+        file.persist(path)
+            .map_err(|err| err.error)
+            .with_context(|| {
+                format!(
+                    "failed to persist rendered template {}",
+                    path.display()
+                )
+            })?;
+        std::fs::File::open(parent)
+            .with_context(|| {
+                format!(
+                    "failed to sync rendered template directory {}",
+                    parent.display()
+                )
+            })?
+            .sync_all()
+            .with_context(|| {
+                format!(
+                    "failed to sync rendered template directory {}",
+                    parent.display()
+                )
+            })?;
+        return Ok(());
+    }
+
+    #[cfg(not(unix))]
+    {
+        std::fs::write(path, rendered).with_context(|| {
+            format!("failed to write rendered template {}", path.display())
+        })?;
+        Ok(())
+    }
+}
