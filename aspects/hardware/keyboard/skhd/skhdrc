# https://cloud.githubusercontent.com/assets/6175959/18551554/35137fc6-7b59-11e6-81a0-bef19ed5db5e.png
f11 [
  "VMWare Fusion" : osascript -e 'tell app "System Events"' -e 'key code 14 using control down' -e 'delay 0.05' -e 'key code 123 using control down' -e 'end'
  *               : osascript -e 'tell application "System Events" to key code 123 using control down'
] 
f12 [
  "VMWare Fusion" : osascript -e 'tell app "System Events"' -e 'key code 14 using control down' -e 'delay 0.05' -e 'key code 124 using control down' -e 'end'
  *               : osascript -e 'tell application "System Events" to key code 124 using control down'
] 
ctrl - 0x1B [
  "VMWare Fusion" ~
  *    : open -g "rectangle://execute-action?name=smaller"
] 
ctrl - 0x18 [
  "VMWare Fusion" ~
  *    : open -g "rectangle://execute-action?name=larger"
] 
cmd - 0x18 [
  "notes" : osascript -e 'tell application "System Events" to keystroke "." using {command down, shift down}'
  * ~
]
cmd - 0x1B [
  "notes" : osascript -e 'tell application "System Events" to keystroke "," using {command down, shift down}'
  * ~
]
ctrl - x [
  "VMWare Fusion" ~
  ".emacs-30.2-wrapped" ~
  "Code" ~
  *   : shortcuts run OpenSpotlight
]
cmd - b  [
  "VMWare Fusion" ~
  "calendar" : osascript \
                -e 'tell application "System Events"' \
                -e '  tell process "Calendar"' \
                -e '    if (exists menu item "Hide Calendar List" of menu "View" of menu bar 1) then' \
                -e '      click menu item "Hide Calendar List" of menu "View" of menu bar 1' \
                -e '    else' \
                -e '      click menu item "Show Calendar List" of menu "View" of menu bar 1' \
                -e '    end if' \
                -e '  end tell' \
                -e 'end tell'
  "reminders" : osascript -e 'tell application "System Events" to keystroke "s" using {command down, option down}'
  "safari" : osascript -e 'tell application "System Events" to keystroke "l" using {command down, shift down}'
  * : omniwmctl command toggle-workspace-bar && omniwmctl command toggle-hidden-bar
]

ctrl - l [
  "VMWare Fusion" ~
  *   : time /Users/m/.cargo/bin/yny --config /Users/m/.config/yeet-and-yoink/config.toml --log-file=/tmp/yeetnyoink/debug.log --profile --log-append move west
]
